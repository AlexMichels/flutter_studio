---
import FeatureIcon from './FeatureIcon.astro'

interface Props {
  t: Record<string, any>
}

const { t } = Astro.props
const { stats } = t
const icons = ['document', 'workflow', 'users']
---

<section class="ai-flow" aria-label={stats.ariaLabel} data-testid="ai-workflow">
  <div class="ai-flow__shape" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>

  <div class="container ai-flow__inner">
    <div class="ai-flow__intro">
      <h2 class="ai-flow__heading" data-scroll-fill>{stats.heading}</h2>
      <p class="ai-flow__summary reveal" style="--d:80ms">{stats.intro}</p>
    </div>

    <ol class="ai-flow__steps">
      {
        stats.steps.map((step: any, i: number) => (
          <li class="ai-flow__step reveal" style={`--d:${180 + i * 70}ms`}>
            <span class="ai-flow__icon"><FeatureIcon name={icons[i]} /></span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .ai-flow {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(3.75rem, 6vw, 5.75rem);
    background: color-mix(in srgb, var(--silver) 20%, var(--paper-warm));
    color: var(--ink);
  }

  .ai-flow__inner {
    position: relative;
    z-index: 1;
  }

  .ai-flow__intro {
    width: min(100%, 66rem);
    margin: 0 auto clamp(2.5rem, 4vw, 3.75rem);
    text-align: center;
  }

  .ai-flow__heading {
    max-width: 13em;
    margin-inline: auto;
    font-size: clamp(2.8rem, 5.4vw, 5.4rem);
  }

  .ai-flow__summary {
    max-width: 43rem;
    margin: 1.5rem auto 0;
    color: var(--ink-soft);
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    line-height: 1.5;
  }

  .ai-flow__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    list-style: none;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--silver) 50%, var(--paper-warm));
    border-radius: 0.35rem;
    background: var(--paper-warm);
  }

  .ai-flow__step {
    display: flex;
    min-width: 0;
    min-height: 13rem;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.25rem clamp(1.25rem, 2.4vw, 2.5rem) 0.5rem 0;
  }

  .ai-flow__step + .ai-flow__step {
    padding-left: clamp(1.25rem, 2.4vw, 2.5rem);
    border-left: 1px solid color-mix(in srgb, var(--silver) 50%, var(--paper-warm));
  }

  .ai-flow__icon {
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    margin-bottom: 2.25rem;
    border-radius: 0.65rem;
    background: var(--ink);
    color: #fff;
  }

  .ai-flow__step h3 {
    margin-bottom: 0.65rem;
    font-size: clamp(1.2rem, 1.5vw, 1.5rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
  }

  .ai-flow__step p {
    max-width: 27em;
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.5;
  }

  .ai-flow__shape {
    position: absolute;
    z-index: 0;
    left: 50%;
    top: 1.25rem;
    width: clamp(10rem, 17vw, 16rem);
    aspect-ratio: 1;
    opacity: 0.72;
    transform: translateX(-50%) rotate(12deg);
  }

  .ai-flow__shape span {
    position: absolute;
    width: 66%;
    aspect-ratio: 1;
    border-radius: 46% 54% 48% 52%;
    background: var(--gold);
    box-shadow: inset 0.7rem 0.9rem 1.4rem rgba(255, 255, 255, 0.24);
  }

  .ai-flow__shape span:nth-child(1) { left: 0; top: 0; }
  .ai-flow__shape span:nth-child(2) { right: 0; top: 0; }
  .ai-flow__shape span:nth-child(3) { left: 18%; bottom: 0; }

  @media (max-width: 47.99rem) {
    .ai-flow__heading {
      font-size: clamp(2.5rem, 12vw, 4.25rem);
    }

    .ai-flow__steps {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }

    .ai-flow__step,
    .ai-flow__step + .ai-flow__step {
      min-height: 0;
      padding: 1rem 0 1.4rem;
      border-left: 0;
    }

    .ai-flow__step + .ai-flow__step {
      border-top: 1px solid color-mix(in srgb, var(--silver) 50%, var(--paper-warm));
    }

    .ai-flow__icon {
      margin-bottom: 2rem;
    }
  }
</style>
