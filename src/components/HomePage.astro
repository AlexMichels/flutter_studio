---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from './Nav.astro'
import Hero from './Hero.astro'
import StatsBand from './StatsBand.astro'
import Services from './Services.astro'
import Work from './Work.astro'
import Process from './Process.astro'
import About from './About.astro'
import Faq from './Faq.astro'
import Contact from './Contact.astro'
import Footer from './Footer.astro'
import { getDict } from '../i18n/index.mjs'
import { professionalService, faqPage, webSite } from '../lib/jsonld.mjs'

interface Props {
  locale: 'de' | 'en'
}

const { locale } = Astro.props
const t = getDict(locale)
const path = locale === 'de' ? '/' : '/en/'

const alternates = [
  { lang: 'de', href: '/' },
  { lang: 'en', href: '/en/' },
  { lang: 'x-default', href: '/' },
]

const jsonLd = [professionalService(locale), faqPage(t), webSite(locale)]
---

<BaseLayout
  t={t}
  title={t.meta.title}
  description={t.meta.description}
  path={path}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <Nav t={t} anchorBase="" homeHref={path} />
  <main id="main">
    <Hero t={t} />
    <StatsBand t={t} />
    <Services t={t} />
    <Work t={t} />
    <Process t={t} />
    <About t={t} />
    <Faq t={t} />
    <Contact t={t} />
  </main>
  <Footer t={t} homeHref={path} />
</BaseLayout>
