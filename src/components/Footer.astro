---
interface Props {
  t: Record<string, any>
  homeHref: string
}

const { t, homeHref } = Astro.props
const { footer } = t
---

<footer class="footer" data-theme="dark">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a class="footer__wordmark" href={homeHref} aria-label="Fluttera Home">
          <img src="/assets/img/fluttera-primary-logo-light.svg" alt="Fluttera" width="159" height="44" />
        </a>
        <p class="footer__tagline">{footer.tagline}</p>
      </div>
      <nav class="footer__nav" aria-label="Legal">
        {footer.legal.map((l: { href: string; label: string }) => <a class="footer__link" href={l.href}>{l.label}</a>)}
        <a class="footer__link" href={homeHref + '#top'}>{footer.backToTop} ↑</a>
      </nav>
    </div>
    <div class="footer__bottom">
      <span class="mono footer__meta">{footer.copyright}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--midnight-deep);
    padding-block: clamp(2.5rem, 6vw, 4rem) 2rem;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--hairline-on-dark);
  }

  /* Official logo, light variant for the dark footer */
  .footer__wordmark {
    display: inline-block;
  }

  .footer__wordmark img {
    height: 44px;
    width: auto;
  }

  .footer__tagline {
    color: var(--soft-on-dark);
    font-size: var(--text-small);
    margin-top: 0.5rem;
  }

  .footer__nav {
    display: flex;
    gap: 1.8rem;
    flex-wrap: wrap;
  }

  .footer__link {
    color: var(--soft-on-dark);
    text-decoration: none;
    font-size: var(--text-small);
    transition: color var(--dur-fast) var(--ease);
  }

  .footer__link:hover {
    color: var(--blue-on-dark);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.6rem;
  }

  .footer__meta {
    color: var(--soft-on-dark);
    font-size: 0.6875rem;
  }
</style>
