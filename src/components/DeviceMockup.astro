---
interface Props {
  ui: Record<string, any>
  badge: string
  platforms: string
}
const { ui, badge, platforms } = Astro.props
const platformItems = platforms.split(' · ')
---

<div class="product" aria-hidden="true">
  <div class="browser">
    <div class="browser__bar">
      <span></span><span></span><span></span>
      <code>app.fluttera.de</code>
    </div>
    <div class="dashboard">
      <aside class="sidebar">
        <strong><i></i> Fluttera</strong>
        {ui.devices.map((device: any, index: number) => <span class:list={[index === 0 && 'active']}>{device.n}</span>)}
      </aside>
      <div class="dashboard__main">
        <div class="search"></div>
        <h3>{ui.header}</h3>
        <div class="metrics">
          <div><small>{ui.devices[0].n}</small><b>45,230</b><em>+12.5%</em></div>
          <div><small>{ui.devices[1].n}</small><b>1,280</b><em>+8.1%</em></div>
          <div><small>{ui.devices[2].n}</small><b>8,915</b><em>+5.3%</em></div>
          <div><small>{ui.devices[3].n}</small><b>3.8%</b><em>+2.2%</em></div>
        </div>
        <div class="chart">
          <svg viewBox="0 0 720 150" preserveAspectRatio="none"><path d="M0 124 C55 72 90 135 145 92 S220 115 275 72 S345 100 405 47 S475 115 525 70 S590 105 635 61 S680 94 720 21"/><path class="fill" d="M0 124 C55 72 90 135 145 92 S220 115 275 72 S345 100 405 47 S475 115 525 70 S590 105 635 61 S680 94 720 21 V150 H0Z"/></svg>
        </div>
        <div class="table-lines"><i></i><i></i><i></i></div>
      </div>
    </div>
  </div>

  <div class="phone">
    <div class="phone__screen">
      <small>09:41</small>
      <h4>{ui.header}</h4>
      <p>{ui.tempRoom}</p>
      <div class="temperature"><b>{ui.tempValue}</b><span>{ui.tempUnit}</span></div>
      <div class="tiles">{ui.devices.map((device: any) => <div><i></i><strong>{device.n}</strong><small>{device.s}</small></div>)}</div>
    </div>
  </div>

  <div class="platforms">
    <span>{badge}</span>
    <div>{platformItems.map((platform) => <span><b>✓</b>{platform}</span>)}</div>
  </div>
</div>

<style>
  .product { position: relative; padding: 0 3rem 4.5rem; }
  .browser { overflow: hidden; border: 1.5px solid var(--hairline); border-radius: var(--radius-s); background: white; box-shadow: var(--shadow-offset); }
  .browser__bar { height: 3.2rem; display: flex; align-items: center; gap: .5rem; padding: 0 1rem; border-bottom: 1px solid var(--hairline); color: var(--ink-soft); }
  .browser__bar span { width: .7rem; height: .7rem; border-radius: 50%; background: #adb1b5; }
  .browser__bar code { margin-left: .75rem; font-family: var(--font-mono); font-size: .8rem; }
  .dashboard { display: grid; grid-template-columns: 11rem 1fr; height: 31rem; }
  .sidebar { border-right: 1px solid #e1e5ea; padding: 1.5rem 1rem; display: flex; flex-direction: column; gap: .65rem; text-align: left; }
  .sidebar strong { font-size: .7rem; margin-bottom: .8rem; }
  .sidebar strong i { display: inline-block; width: 1.25rem; height: 1.25rem; border: 5px solid var(--blue); border-radius: 50%; vertical-align: middle; margin-right: .4rem; }
  .sidebar > span { border-radius: .45rem; padding: .55rem .65rem; font-size: .7rem; color: var(--ink-soft); overflow: hidden; white-space: nowrap; }
  .sidebar > span.active { background: #edf3fc; color: var(--blue); }
  .dashboard__main { padding: 1.2rem; overflow: hidden; text-align: left; }
  .search { width: 42%; height: 2rem; border: 1px solid #d9dfe7; border-radius: .45rem; margin-bottom: 1.2rem; }
  .dashboard h3 { font-size: 1.2rem; letter-spacing: -.02em; margin-bottom: 1rem; }
  .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: .65rem; }
  .metrics > div { display: flex; flex-direction: column; padding: .75rem; border: 1px solid #d9dfe7; border-radius: .65rem; }
  .metrics small { font-size: .58rem; color: var(--ink-soft); white-space: nowrap; overflow: hidden; }
  .metrics b { font-size: 1.3rem; line-height: 1.15; }
  .metrics em { color: #16945d; font-size: .55rem; font-style: normal; }
  .chart { height: 10.5rem; margin-top: .75rem; border: 1px solid #d9dfe7; border-radius: .65rem; padding: 1rem; background: repeating-linear-gradient(#fff, #fff 32px, #edf0f4 33px); }
  .chart svg { width: 100%; height: 100%; overflow: visible; }
  .chart path { fill: none; stroke: var(--blue); stroke-width: 3; }
  .chart .fill { fill: rgba(40,84,189,.14); stroke: none; }
  .table-lines { width: 54%; margin-top: .75rem; padding: .8rem; border: 1px solid #d9dfe7; border-radius: .65rem; }
  .table-lines i { display: block; height: 1px; background: #d9dfe7; margin: .75rem 0; }
  .phone { position: absolute; left: 0; bottom: 0; width: 15rem; padding: .55rem; border: 5px solid #242629; border-radius: 2rem; background: #242629; transform: rotate(-4deg); box-shadow: 0 20px 35px rgba(30,40,60,.2); }
  .phone__screen { min-height: 25rem; padding: 1.3rem 1rem; border-radius: 1.45rem; background: #f7f9fc; text-align: left; }
  .phone h4 { margin: 1.2rem 0 .15rem; font-size: 1.05rem; }
  .phone p { color: var(--ink-soft); font-size: .7rem; }
  .temperature { margin: 1rem 0; padding: 1rem; border-radius: .8rem; color: white; background: var(--blue); }
  .temperature b { font-size: 2rem; }.temperature span { font-size: .75rem; }
  .tiles { display: grid; grid-template-columns: 1fr 1fr; gap: .55rem; }
  .tiles div { display: flex; flex-direction: column; gap: .2rem; min-width: 0; padding: .65rem; border: 1px solid #e1e5ea; border-radius: .65rem; background: white; }
  .tiles i { width: 1rem; height: 1rem; border-radius: 50%; background: var(--blue-wash); }
  .tiles strong,.tiles small { overflow: hidden; white-space: nowrap; font-size: .52rem; }.tiles small{color:var(--ink-soft)}
  .platforms { position: absolute; right: 0; top: -2rem; width: 15rem; padding: 1.2rem; border: 1px solid var(--hairline); border-radius: var(--radius-s); background: white; box-shadow: var(--shadow-offset); transform: rotate(3deg); text-align: left; }
  .platforms > span { display: block; margin-bottom: .8rem; color: var(--ink-soft); font-family: var(--font-mono); font-size: .75rem; }
  .platforms div { display: grid; grid-template-columns: 1fr 1fr; gap: .4rem .5rem; font-size: .8rem; }
  .platforms div span { display: flex; gap: .35rem; align-items: center; }
  .platforms b { color: var(--blue); }
  @media (max-width: 48rem) {
    .product { padding: 0 0 2rem; }
    .dashboard { grid-template-columns: 5rem 1fr; height: 22rem; }
    .sidebar { padding-inline: .5rem; }.sidebar strong{font-size:0}.sidebar > span{font-size:.5rem}.metrics{grid-template-columns:1fr 1fr}.metrics>div:nth-child(n+3){display:none}
    .phone { width: 9rem; bottom: -1rem; }.phone__screen{min-height:15rem;padding:.8rem .55rem}.phone h4{font-size:.7rem}.temperature{padding:.55rem}.temperature b{font-size:1.2rem}.tiles div{padding:.35rem}.tiles strong,.tiles small{font-size:.38rem}
    .platforms { width: 10rem; right: -.5rem; top: -1rem; padding: .75rem; }.platforms>span{font-size:.5rem}.platforms div{font-size:.55rem}
  }
</style>
