---
import { CALENDLY_URL } from '../lib/site.mjs'

interface Props {
  label: string
  class?: string
  testId?: string
}

const { label, class: className, testId } = Astro.props
---

{/* Opens the Calendly page directly in a new tab — the popup widget was
    removed on purpose (unreliable); data-calendly stays as a marker/test hook. */}
<a
  class:list={['btn', 'btn--primary', className]}
  href={CALENDLY_URL}
  target="_blank"
  rel="noopener"
  data-calendly
  data-testid={testId}
>{label}</a>
