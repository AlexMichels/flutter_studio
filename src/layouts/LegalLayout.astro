---
import BaseLayout from './BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { getDict } from '../i18n/index.mjs'

interface Props {
  title: string
  description: string
  path: string
}

const { title, description, path } = Astro.props
// Legal pages exist in German only; German dictionary drives nav and footer.
const t = getDict('de')
---

<BaseLayout t={t} title={title} description={description} path={path} noindex={true}>
  <Nav t={t} anchorBase="/" homeHref="/" />
  <main id="main" class="legal">
    <div class="container legal__container">
      <a class="link-bleed legal__back" href="/">← {t.legalPage.backHome}</a>
      <slot />
    </div>
  </main>
  <Footer t={t} homeHref="/" />
</BaseLayout>

<style is:global>
  .legal {
    padding: 8rem 0 5rem;
    background: var(--paper);
  }

  .legal__container {
    max-width: 46rem;
  }

  .legal__back {
    color: var(--blue);
    margin-bottom: 3rem;
  }

  .legal h1 {
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    margin: 2.5rem 0 2rem;
  }

  /* Running heads in long legal copy stay in the body face — Orbitron at these
     sizes reads like poster type. */
  .legal h2 {
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    text-transform: none;
    font-size: 1.6rem;
    margin: 2.8rem 0 1rem;
  }

  .legal h3 {
    font-size: 1.25rem;
    margin: 2rem 0 0.8rem;
  }

  .legal h4 {
    font-family: var(--font-body);
    font-size: 1.05rem;
    margin: 1.6rem 0 0.6rem;
  }

  .legal p,
  .legal li {
    color: var(--ink-soft);
    margin-bottom: 0.9rem;
  }

  .legal ul {
    padding-left: 1.2rem;
  }
</style>
