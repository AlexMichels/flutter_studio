---
import '../styles/global.css'
import { SITE_URL, GA_ID } from '../lib/site.mjs'

interface Props {
  t: Record<string, any>
  title: string
  description: string
  /** Canonical path, e.g. '/' or '/en/' or '/impressum.html' */
  path: string
  /** hreflang alternates; omit for single-language pages */
  alternates?: { lang: string; href: string }[]
  jsonLd?: object[]
  noindex?: boolean
  ogImage?: string
}

const {
  t,
  title,
  description,
  path,
  alternates = [],
  jsonLd = [],
  noindex = false,
  ogImage = `/assets/og/og-${t.locale}.png`,
} = Astro.props

const canonical = new URL(path, SITE_URL).href
const ogImageUrl = new URL(ogImage, SITE_URL).href
---

<!doctype html>
<html lang={t.htmlLang} style="color-scheme: only light;">
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="only light" />
    <meta name="theme-color" content="#f4f7fb" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.classList.add('js')

      // Preserve links to the former query-parameter English locale.
      const legacyLocale = new URLSearchParams(window.location.search).get('lang')
      if (window.location.pathname === '/' && legacyLocale === 'en') {
        window.location.replace(`/en/${window.location.hash}`)
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alexander Michels" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.lang} href={new URL(alt.href, SITE_URL).href} />
      ))
    }

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fluttera" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={t.meta.ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/img/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/assets/og/apple-touch-icon.png" />

    <link rel="preload" href="/fonts/geist-vf-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/anton-400-latin.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}

    <!-- Google tag (gtag.js) -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag('js', new Date())
      gtag('config', GA_ID)
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">{t.skipLink}</a>
    <slot />
    <script>
      import '../scripts/main.js'
    </script>
  </body>
</html>
